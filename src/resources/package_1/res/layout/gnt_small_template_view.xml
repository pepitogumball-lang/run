<?xml version='1.0' encoding='utf-8' ?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:discordbotdesinger="http://schemas.android.com/apk/res-auto">
  <com.google.android.gms.ads.nativead.NativeAdView android:id="@id/native_ad_view"
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_centerInParent="true">
    <androidx.constraintlayout.widget.ConstraintLayout android:background="@drawable/gnt_outline_shape"
                          android:layout_width="fill_parent"
                          android:layout_height="wrap_content"
                          android:layout_centerInParent="true">
      <androidx.constraintlayout.widget.ConstraintLayout android:orientation="horizontal"
                            android:id="@id/background"
                            android:layout_width="@dimen/gnt_no_size"
                            android:layout_height="@dimen/gnt_no_size"
                            android:layout_marginTop="@dimen/gnt_default_margin"
                            android:layout_marginBottom="@dimen/gnt_default_margin"
                            android:layout_marginStart="@dimen/gnt_default_margin"
                            android:layout_marginEnd="@dimen/gnt_default_margin"
                            discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                            discordbotdesinger:layout_constraintDimensionRatio="H,4:1"
                            discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                            discordbotdesinger:layout_constraintStart_toStartOf="parent"
                            discordbotdesinger:layout_constraintTop_toTopOf="parent">
        <ImageView android:id="@id/icon"
                   android:layout_width="0.0dp"
                   android:layout_height="fill_parent"
                   android:layout_marginTop="@dimen/gnt_no_margin"
                   android:layout_marginBottom="@dimen/gnt_no_margin"
                   android:layout_weight="0.0"
                   android:layout_marginStart="@dimen/gnt_no_margin"
                   android:layout_marginEnd="@dimen/gnt_no_margin"
                   discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                   discordbotdesinger:layout_constraintDimensionRatio="H,1:1"
                   discordbotdesinger:layout_constraintEnd_toStartOf="@id/content"
                   discordbotdesinger:layout_constraintStart_toStartOf="parent"
                   discordbotdesinger:layout_constraintTop_toTopOf="parent" />
        <androidx.constraintlayout.widget.ConstraintLayout android:orientation="vertical"
                              android:id="@id/content"
                              android:layout_width="@dimen/gnt_no_size"
                              android:layout_height="@dimen/gnt_no_size"
                              android:layout_marginTop="@dimen/gnt_no_margin"
                              android:layout_marginBottom="@dimen/gnt_no_margin"
                              android:layout_marginStart="@dimen/gnt_default_margin"
                              android:layout_marginEnd="@dimen/gnt_default_margin"
                              discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                              discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                              discordbotdesinger:layout_constraintStart_toEndOf="@id/icon"
                              discordbotdesinger:layout_constraintTop_toTopOf="parent">
          <LinearLayout android:orientation="horizontal"
                        android:id="@id/headline"
                        android:background="@android:color/transparent"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/gnt_no_size"
                        android:layout_weight="@dimen/gnt_text_row_weight"
                        discordbotdesinger:layout_constraintBottom_toTopOf="@id/row_two"
                        discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                        discordbotdesinger:layout_constraintStart_toStartOf="parent"
                        discordbotdesinger:layout_constraintTop_toTopOf="parent">
            <TextView android:textSize="@dimen/gnt_text_size_large"
                      android:textStyle="bold"
                      android:textColor="@color/gnt_gray"
                      android:id="@id/primary"
                      android:layout_width="wrap_content"
                      android:layout_height="fill_parent"
                      android:layout_marginTop="@dimen/gnt_no_margin"
                      android:layout_marginBottom="@dimen/gnt_no_margin"
                      android:lines="1"
                      android:layout_marginStart="@dimen/gnt_no_margin"
                      android:layout_marginEnd="@dimen/gnt_no_margin"
                      discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                      discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                      discordbotdesinger:layout_constraintStart_toEndOf="parent"
                      discordbotdesinger:layout_constraintTop_toTopOf="parent" />
          </LinearLayout>
          <LinearLayout android:orientation="horizontal"
                        android:id="@id/row_two"
                        android:layout_width="fill_parent"
                        android:layout_height="@dimen/gnt_no_size"
                        android:layout_weight="@dimen/gnt_text_row_weight"
                        discordbotdesinger:layout_constraintBottom_toTopOf="@id/cta"
                        discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                        discordbotdesinger:layout_constraintStart_toStartOf="parent"
                        discordbotdesinger:layout_constraintTop_toBottomOf="@id/headline">
            <TextView android:textSize="@dimen/gnt_ad_indicator_text_size"
                      android:textStyle="bold"
                      android:textColor="@color/gnt_ad_green"
                      android:gravity="center"
                      android:id="@id/ad_notification_view"
                      android:background="@drawable/gnt_rounded_corners_shape"
                      android:layout_width="@dimen/gnt_ad_indicator_width"
                      android:layout_height="@dimen/gnt_ad_indicator_height"
                      android:layout_marginTop="@dimen/gnt_ad_indicator_top_margin"
                      android:text="Ad"
                      android:layout_marginStart="@dimen/gnt_no_margin"
                      android:layout_marginEnd="@dimen/gnt_default_margin"
                      discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                      discordbotdesinger:layout_constraintStart_toStartOf="parent"
                      discordbotdesinger:layout_constraintTop_toTopOf="parent" />
            <RatingBar android:textSize="@dimen/gnt_text_size_small"
                       android:textColor="@color/gnt_gray"
                       android:id="@id/rating_bar"
                       android:background="@android:color/transparent"
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:layout_marginTop="@dimen/gnt_no_margin"
                       android:layout_marginBottom="@dimen/gnt_no_margin"
                       android:numStars="5"
                       android:stepSize="0.1"
                       android:lines="1"
                       android:layout_marginStart="@dimen/gnt_no_margin"
                       android:layout_marginEnd="@dimen/gnt_no_margin"
                       discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                       discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                       discordbotdesinger:layout_constraintStart_toEndOf="@id/ad_notification_view"
                       discordbotdesinger:layout_constraintTop_toTopOf="parent"
                       style="?android:attr/ratingBarStyleSmall" />
            <TextView android:textSize="@dimen/gnt_text_size_small"
                      android:textColor="@color/gnt_gray"
                      android:gravity="top"
                      android:id="@id/secondary"
                      android:background="@color/gnt_white"
                      android:layout_width="wrap_content"
                      android:layout_height="fill_parent"
                      android:layout_marginTop="@dimen/gnt_no_margin"
                      android:layout_marginBottom="@dimen/gnt_no_margin"
                      android:lines="1"
                      android:layout_marginStart="@dimen/gnt_no_margin"
                      android:layout_marginEnd="@dimen/gnt_no_margin"
                      discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                      discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                      discordbotdesinger:layout_constraintStart_toEndOf="@id/ad_notification_view"
                      discordbotdesinger:layout_constraintTop_toTopOf="parent" />
          </LinearLayout>
          <androidx.appcompat.widget.AppCompatButton android:textColor="@color/gnt_white"
                                android:gravity="center"
                                android:id="@id/cta"
                                android:background="@color/gnt_blue"
                                android:layout_width="fill_parent"
                                android:layout_height="@dimen/gnt_no_size"
                                android:lines="1"
                                discordbotdesinger:layout_constraintBottom_toBottomOf="parent"
                                discordbotdesinger:layout_constraintEnd_toEndOf="parent"
                                discordbotdesinger:layout_constraintHeight_percent="0.35"
                                discordbotdesinger:layout_constraintStart_toStartOf="parent"
                                discordbotdesinger:layout_constraintTop_toBottomOf="@id/row_two" />
        </androidx.constraintlayout.widget.ConstraintLayout>
      </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
  </com.google.android.gms.ads.nativead.NativeAdView>
</merge>